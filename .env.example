# ========================================
# TripApp - Environment Variables
# ========================================
# העתיקי קובץ זה ל-.env.local ומלאי את הערכים

# ========================================
# חובה - Supabase (Database + Auth + Storage)
# ========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ========================================
# חובה - Mapbox (מפות)
# ========================================
VITE_MAPBOX_TOKEN=pk.your-mapbox-token-here

# ========================================
# אופציונלי - Anthropic Claude API (עוזר AI)
# ========================================
# בלי זה - טאב הצ'אט יציג מסך "בקרוב"
# כל שאר הפיצ'רים יעבדו רגיל
# כשתפתרי את החיוב, פשוט הוסיפי את המפתח כאן ורענני
# VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
